   "source": [
    "\n",
    "import shutil, os\n",
    "\n",
    "folder = \"labels\"\n",
    "\n",
    "if os.path.isdir(folder):\n",
    "    print(f\"Deleting folder: {folder}\")\n",
    "    shutil.rmtree(folder)\n",
    "    print(\"Done.\")\n",
    "else:\n",
    "    print(\"Folder not found.\")\n"
   ]
